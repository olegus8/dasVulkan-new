options gen2
options indenting = 4
options strict_smart_pointers = true

module vulkan_lint shared private

//! dasVulkan lint pass — VK001: prefer the boost wrapper over a raw Vulkan call.
//!
//! Opt-in: ``require vulkan/vulkan_lint``. Runs on the consumer file only
//! (``prog.getThisModule``), so required wrapper modules are not linted. Per-file
//! opt-out: ``options _allow_vulkan_raw = true`` (a lint-macro ``macro_error`` is
//! not ``// nolint``-suppressible, so the file-level option is the only escape).
//!
//! The raw -> wrapper map (``VK_WRAPPED``) is generated by the binding generator
//! (``vulkan_lint_data``), so it stays in sync as wrappers are added. A raw
//! ``vk*`` call with no wrapper (a genuine escape hatch) is never flagged.

require daslib/ast_boost
require vulkan/vulkan_lint_data

class VulkanLintVisitor : AstVisitor {
    @do_not_delete current_function : Function?

    def override preVisitFunction(var fn : FunctionPtr) : void {
        current_function = fn
    }

    def override visitFunction(var fn : FunctionPtr) : FunctionPtr {
        current_function = null
        return <- fn
    }

    def override preVisitExprCall(var expr : ExprCall?) : void {
        // Skip null guards, macro-generated bodies, and macro-synthesized call
        // sites (whose `at` points outside the containing function's file).
        if (expr.func == null || expr.func._module == null
                || (current_function != null
                    && (current_function.flags.generated
                        || (current_function.at.fileInfo != null
                            && expr.at.fileInfo != current_function.at.fileInfo)))
                || expr.func._module.name != "vulkan") {
            return
        }
        let fname = string(expr.func.name)
        let wrapper = VK_WRAPPED?[fname] ?? ""
        if (wrapper != "") {
            compiling_program() |> macro_error(expr.at,
                "VK001: raw {fname} has a boost wrapper '{wrapper}' — prefer it. For a deliberate raw call, put 'options _allow_vulkan_raw = true' at the top of the file.")
        }
    }
}

[lint_macro]
class VulkanLintMacro : AstPassMacro {
    def override apply(prog : ProgramPtr; mod : Module?) : bool {
        let opted_out = prog._options |> find_arg("_allow_vulkan_raw") ?as tBool ?? false
        if (opted_out) {
            return true
        }
        var v = new VulkanLintVisitor()
        make_visitor(*v) $(adapter) {
            visit_module(prog, adapter, prog.getThisModule)
        }
        unsafe { delete v; }
        return true
    }
}
