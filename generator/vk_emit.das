options gen2
options indenting = 4
options persistent_heap = true

module vk_emit shared

require vk_model
require vk_naming
require daslib/fio
require strings
require daslib/strings_boost
require math

// emitted C++ braces -- das string interpolation reserves {}
let OB = "\{"
let CB = "\}"

let GEN_HEADER = "// generated by generator/generate.das -- DO NOT EDIT\n\n"

//! platform protects we emit; everything else (fuchsia, ggp, qnx, ...) is skipped wholesale
let SUPPORTED_PROTECTS : table<string> <- {
    "",
    "VK_USE_PLATFORM_WIN32_KHR",
    "VK_USE_PLATFORM_XLIB_KHR",
    "VK_USE_PLATFORM_WAYLAND_KHR",
    "VK_USE_PLATFORM_METAL_EXT"
}

//! C scalar type -> C++ emission type usable with makeType<> (das-compatible)
let SCALAR_MAP : table<string; string> <- {
    "uint8_t" => "uint8_t",
    "int8_t" => "int8_t",
    "uint16_t" => "uint16_t",
    "int16_t" => "int16_t",
    "uint32_t" => "uint32_t",
    "int32_t" => "int32_t",
    "uint64_t" => "uint64_t",
    "int64_t" => "int64_t",
    "int" => "int32_t",
    "float" => "float",
    "double" => "double",
    "size_t" => "uint64_t",
    "char" => "char"
}

//! foreign platform types for the supported window systems
let FOREIGN_MAP : table<string; string> <- {
    "HINSTANCE" => "void *",
    "HWND" => "void *",
    "HMONITOR" => "void *",
    "HANDLE" => "void *",
    "DWORD" => "uint32_t",
    "LPCWSTR" => "void *",
    "SECURITY_ATTRIBUTES" => "void",
    "Display" => "void",
    "Window" => "uint64_t",
    "VisualID" => "uint64_t",
    "RROutput" => "uint64_t",
    "wl_display" => "void",
    "wl_surface" => "void",
    "CAMetalLayer" => "void",
    "MTLDevice_id" => "void *",
    "MTLCommandQueue_id" => "void *",
    "MTLBuffer_id" => "void *",
    "MTLTexture_id" => "void *",
    "MTLSharedEvent_id" => "void *",
    "IOSurfaceRef" => "void *"
}

enum FlagsKind {
    not_flags
    flags32
    flags64
    flag_bits32
    flag_bits64
}

struct FlagsInfo {
    kind : FlagsKind
    alias_name : string         //! das-side bitfield alias (the canonical Flags name)
    canonical : string          //! canonical Flags typedef name (makeVkFlags_<canonical>)
}

struct BitfieldSpec {
    flags_name : string         //! canonical Flags name = das alias
    bits_enum : string          //! the FlagBits C enum name ("" if reserved-empty)
    is64 : bool
    bit_names : array<string>   //! position-indexed das bit names ("_bN" placeholders)
    multibit : array<string>    //! full C names of multi-bit/combo values -> constants
    guard : string
    protect : string
    aliases : array<string>     //! alias Flags typedef names
}

struct EmitModel {
    flags_lookup : table<string; FlagsInfo>     //! Flags AND FlagBits names -> info
    bitfields : array<BitfieldSpec>
    plain_enums : table<string; int>            //! enum name -> reg.enums index (non-bitmask, enabled)
    handle_names : table<string>                //! enabled canonical handle names
    struct_emit : table<string>                 //! structs we actually emit (non-alias)
    skipped : table<string; string>
}

def private supported(protect : string) : bool {
    return key_exists(SUPPORTED_PROTECTS, protect)
}

def private guard_open(f : FILE const?; guard, protect : string) {
    return if (empty(guard))
    if (!empty(protect)) {
        fprint(f, "#if defined({guard}) && defined({protect})\n")
    } else {
        fprint(f, "#if defined({guard})\n")
    }
}

[unused_argument(protect)]
def private guard_close(f : FILE const?; guard, protect : string) {
    return if (empty(guard))
    fprint(f, "#endif\n")
}

// ===== model preparation =====

def private build_flags_lookup(reg : VkRegistry; var em : EmitModel) {
    // canonical bitmask typedefs first
    for (b in reg.bitmasks) {
        continue if (!empty(b.alias) || !key_exists(reg.enabled_types, b.name) || !supported(b.protect))
        em.flags_lookup[b.name] = FlagsInfo(
            kind = b.is64 ? FlagsKind.flags64 : FlagsKind.flags32,
            alias_name = b.name,
            canonical = b.name
        )
        if (!empty(b.bits_enum)) {
            em.flags_lookup[b.bits_enum] = FlagsInfo(
                kind = b.is64 ? FlagsKind.flag_bits64 : FlagsKind.flag_bits32,
                alias_name = b.name,
                canonical = b.name
            )
        }
    }
    // alias typedefs point at their canonical's info
    for (b in reg.bitmasks) {
        continue if (empty(b.alias))
        let canon = em.flags_lookup?[b.alias] ?? FlagsInfo()
        if (canon.kind != FlagsKind.not_flags) {
            em.flags_lookup[b.name] = FlagsInfo(
                kind = canon.kind,
                alias_name = canon.alias_name,
                canonical = canon.canonical
            )
        }
    }
}

def private build_bitfields(reg : VkRegistry; var em : EmitModel) {
    for (b in reg.bitmasks) {
        continue if (!empty(b.alias) || !key_exists(reg.enabled_types, b.name) || !supported(b.protect))
        var spec = BitfieldSpec(
            flags_name = b.name,
            bits_enum = b.bits_enum,
            is64 = b.is64,
            guard = b.guard,
            protect = b.protect
        )
        let ei = reg.enum_index?[b.bits_enum] ?? -1
        if (!empty(b.bits_enum) && ei >= 0) {
            let ed & = unsafe(reg.enums[ei])
            let prefix = enum_value_prefix(b.bits_enum, true, reg.vendor_tags)
            var max_bit = -1
            for (e in ed.entries) {
                if (!e.is_alias && e.bitpos >= 0 && e.bitpos > max_bit) {
                    max_bit = e.bitpos
                }
            }
            if (max_bit >= 0) {
                spec.bit_names |> resize(max_bit + 1)
                for (i in range(max_bit + 1)) {
                    spec.bit_names[i] = "_b{i}"
                }
                var used : table<string>
                for (e in ed.entries) {
                    continue if (e.is_alias || e.bitpos < 0)
                    let short = enum_short_name(prefix, e.name)
                    let bn = bit_name(short)
                    if (key_exists(used, bn) || empty(bn)) {
                        continue    // first writer wins; placeholder stays
                    }
                    if (spec.bit_names[e.bitpos] |> starts_with("_b")) {
                        used |> insert(bn)
                        spec.bit_names[e.bitpos] = bn
                    }
                }
            }
            for (e in ed.entries) {
                if (!e.is_alias && e.bitpos < 0) {
                    spec.multibit |> push(e.name)
                }
            }
        }
        em.bitfields |> emplace(spec)
    }
    for (b in reg.bitmasks) {
        continue if (empty(b.alias) || !key_exists(reg.enabled_types, b.name))
        for (spec in em.bitfields) {
            if (spec.flags_name == b.alias) {
                spec.aliases |> push(b.name)
                break
            }
        }
    }
}

def private member_type_known(m : VkMember; reg : VkRegistry; em : EmitModel) : string {
    let tn = m.type_name
    return "" if (tn == "void" || key_exists(SCALAR_MAP, tn) || key_exists(reg.base_types, tn) || key_exists(FOREIGN_MAP, tn) || key_exists(reg.func_pointers, tn))
    let fi = em.flags_lookup?[tn] ?? FlagsInfo()
    return "" if (fi.kind != FlagsKind.not_flags || key_exists(em.handle_names, tn))
    if (key_exists(reg.enum_index, tn)) {
        // plain enum must be emitted (enabled); bitmask enums resolved via flags_lookup above
        return key_exists(em.plain_enums, tn) ? "" : "enum {tn} not emitted"
    }
    if (key_exists(reg.struct_index, tn)) {
        if (key_exists(em.skipped, tn)) {
            return "depends on skipped {tn}"
        }
        if (key_exists(em.struct_emit, tn)) {
            return ""
        }
        return "struct {tn} not emitted"
    }
    return "unknown type {tn}"
}

def private resolve_struct_alias(reg : VkRegistry; name : string) : string {
    var cur = name
    var hops = 0
    while (hops < 8) {
        let idx = reg.struct_index?[cur] ?? -1
        return "" if (idx < 0)
        let al = reg.structs[idx].alias
        return cur if (empty(al))
        cur = al
        hops++
    }
    return ""
}

def private compute_struct_set(reg : VkRegistry; var em : EmitModel) {
    // seed: every enabled, protect-supported, non-alias struct
    for (s in reg.structs) {
        continue if (!empty(s.alias) || !key_exists(reg.enabled_types, s.name))
        if (!supported(s.protect)) {
            em.skipped[s.name] = "platform {s.protect}"
            continue
        }
        var reason = ""
        for (m in s.members) {
            if (m.bit_width > 0) {
                reason = "C bitfield member {m.name}"
                break
            }
            if (m.type_name |> starts_with("StdVideo")) {
                reason = "video std type {m.type_name}"
                break
            }
        }
        if (empty(reason)) {
            em.struct_emit |> insert(s.name)
        } else {
            em.skipped[s.name] = reason
        }
    }
    // fixpoint: drop structs whose members reference unknown/skipped types
    var changed = true
    while (changed) {
        changed = false
        var drop : array<string>
        for (s in reg.structs) {
            continue if (!key_exists(em.struct_emit, s.name))
            for (m in s.members) {
                let why = member_type_known(m, reg, em)
                if (!empty(why)) {
                    drop |> push(s.name)
                    em.skipped[s.name] = why
                    break
                }
            }
        }
        for (d in drop) {
            em.struct_emit |> erase(d)
            changed = true
        }
    }
}

def public build_emit_model(reg : VkRegistry) : EmitModel {
    var em : EmitModel
    for (h in reg.handles) {
        continue if (!empty(h.alias) || !key_exists(reg.enabled_types, h.name) || !supported(h.protect))
        em.handle_names |> insert(h.name)
    }
    build_flags_lookup(reg, em)
    build_bitfields(reg, em)
    for (e in reg.enums) {
        continue if (e.is_bitmask || !key_exists(reg.enabled_types, e.name))
        em.plain_enums[e.name] = reg.enum_index?[e.name] ?? -1
    }
    compute_struct_set(reg, em)
    return <- em
}

// ===== emission: constants =====

def public emit_consts(reg : VkRegistry; out_dir : string) {
    fopen("{out_dir}/dasVULKAN.gen_consts.cpp", "wb") $(f) {
        panic("can't write gen_consts") if (f == null)
        fprint(f, GEN_HEADER)
        fprint(f, "#include \"dasVULKAN.h\"\n\nnamespace das {OB}\n\n")
        fprint(f, "void das_vulkan_init_consts(Module & mod, ModuleLibrary & lib) {OB}\n")
        for (c in reg.constants) {
            continue if (c.is_alias)
            let guard = reg.enabled_constants?[c.name] ?? ""
            let protect = reg.ext_protect?[guard] ?? ""
            continue if (!supported(protect))
            var ct = "uint32_t"
            if (c.ctype == "uint64_t") {
                ct = "uint64_t"
            } elif (c.ctype == "float") {
                ct = "float"
            }
            guard_open(f, guard, protect)
            fprint(f, "    addConstant<{ct}>(mod, \"{c.name}\", {ct}({c.name}));\n")
            guard_close(f, guard, protect)
        }
        fprint(f, "{CB}\n\n{CB}\n")
    }
}

// ===== emission: plain enums =====

def public emit_enums(reg : VkRegistry; em : EmitModel; out_dir : string; var init_fns : array<string>; var header_lines : array<string>) {
    let per_chunk = 40
    var chunk = -1
    var in_chunk = 999999
    var f : FILE const?
    var names <- [for (nm in keys(em.plain_enums)); nm]
    names |> sort()
    for (nm in names) {
        let ei = em.plain_enums?[nm] ?? -1
        continue if (ei < 0)
        let e & = unsafe(reg.enums[ei])
        let guard = reg.enabled_types?[e.name] ?? ""
        let protect = reg.ext_protect?[guard] ?? ""
        continue if (!supported(protect))
        if (in_chunk >= per_chunk) {
            if (f != null) {
                fprint(f, "{CB}\n")        // close namespace das (registration fn is appended later)
                fclose(f)
            }
            chunk++
            in_chunk = 0
            f = fopen("{out_dir}/dasVULKAN.gen_enums_{chunk}.cpp", "wb")
            panic("can't write gen_enums_{chunk}") if (f == null)
            fprint(f, GEN_HEADER)
            fprint(f, "#include \"dasVULKAN.h\"\n\nnamespace das {OB}\n\n")
            // class bodies first, then one init fn at the end of the chunk
            init_fns |> push("das_vulkan_init_enums_{chunk}")
        }
        // class
        guard_open(f, guard, protect)
        fprint(f, "class Enumeration_{e.name} : public Enumeration {OB}\npublic:\n")
        fprint(f, "    Enumeration_{e.name}() : Enumeration(\"{e.name}\") {OB}\n")
        fprint(f, "        external = true;\n        cppName = \"{e.name}\";\n")
        fprint(f, "        baseType = (Type) ToBasicType< underlying_type<{e.name}>::type >::type;\n")
        let prefix = enum_value_prefix(e.name, false, reg.vendor_tags)
        var used : table<string>
        for (en in e.entries) {
            let short = enum_short_name(prefix, en.name)
            if (key_exists(used, short)) {
                continue
            }
            used |> insert(short)
            let eg = en.guard
            let need_g = !empty(eg) && eg != guard
            if (need_g) {
                fprint(f, "#if defined({eg})\n")
            }
            fprint(f, "        addI(\"{short}\", int64_t({en.name}), LineInfo());\n")
            if (need_g) {
                fprint(f, "#endif\n")
            }
        }
        fprint(f, "    {CB}\n{CB};\n")
        guard_close(f, guard, protect)
        fprint(f, "\n")
        in_chunk++
        // header: factory + cast
        header_lines |> push(build_enum_header(e.name, guard, protect))
    }
    if (f != null) {
        fprint(f, "{CB}\n")        // close namespace das (registration fn is appended later)
        fclose(f)
    }
    // second pass: registration functions need the classes; append registration fn per chunk file
    // (classes and registration live in the same chunk -- rewrite files with registration appended)
    // simpler: emit registration inline above; instead we re-open and append
    append_enum_registrations(reg, em, out_dir, per_chunk)
}

def private build_enum_header(name, guard, protect : string) : string {
    return build_string() $(var w) {
        if (!empty(guard)) {
            if (!empty(protect)) {
                w |> write("#if defined({guard}) && defined({protect})\n")
            } else {
                w |> write("#if defined({guard})\n")
            }
        }
        w |> write("DAS_BASE_BIND_ENUM_FACTORY({name}, \"{name}\")\n")
        w |> write("DAS_BIND_ENUM_CAST({name})\n")
        if (!empty(guard)) {
            w |> write("#endif\n")
        }
    }
}

def private append_enum_registrations(reg : VkRegistry; em : EmitModel; out_dir : string; per_chunk : int) {
    var names <- [for (nm in keys(em.plain_enums)); nm]
    names |> sort()
    var emitted : array<tuple<name : string; guard : string; protect : string>>
    for (nm in names) {
        let guard = reg.enabled_types?[nm] ?? ""
        let protect = reg.ext_protect?[guard] ?? ""
        continue if (!supported(protect))
        emitted |> push((name = nm, guard = guard, protect = protect))
    }
    var chunk = 0
    var i = 0
    while (i < length(emitted)) {
        let hi = min(i + per_chunk, length(emitted))
        fopen("{out_dir}/dasVULKAN.gen_enums_{chunk}.cpp", "ab") $(f) {
            panic("can't append gen_enums_{chunk}") if (f == null)
            fprint(f, "\nnamespace das {OB}\n\nvoid das_vulkan_init_enums_{chunk}(Module & mod, ModuleLibrary & lib) {OB}\n")
            for (j in range(i, hi)) {
                let it & = unsafe(emitted[j])
                guard_open(f, it.guard, it.protect)
                fprint(f, "    mod.addEnumeration(new Enumeration_{it.name}());\n")
                guard_close(f, it.guard, it.protect)
            }
            fprint(f, "{CB}\n\n{CB}\n")
        }
        chunk++
        i = hi
    }
}

// ===== emission: bitfield flags =====

[unused_argument(reg)]
def public emit_flags(reg : VkRegistry; em : EmitModel; out_dir : string; var header_lines : array<string>) {
    fopen("{out_dir}/dasVULKAN.gen_flags.cpp", "wb") $(f) {
        panic("can't write gen_flags") if (f == null)
        fprint(f, GEN_HEADER)
        fprint(f, "#include \"dasVULKAN.h\"\n\nnamespace das {OB}\n\n")
        for (b in em.bitfields) {
            guard_open(f, b.guard, b.protect)
            fprint(f, "TypeDeclPtr makeVkFlags_{b.flags_name}() {OB}\n")
            let bft = b.is64 ? "Type::tBitfield64" : "Type::tBitfield"
            fprint(f, "    auto ft = new TypeDecl({bft});\n")
            fprint(f, "    ft->alias = \"{b.flags_name}\";\n")
            if (!empty(b.bit_names)) {
                fprint(f, "    ft->argNames = {OB} ")
                var first = true
                for (bn in b.bit_names) {
                    if (!first) {
                        fprint(f, ", ")
                    }
                    fprint(f, "\"{bn}\"")
                    first = false
                }
                fprint(f, " {CB};\n")
            }
            fprint(f, "    return ft;\n{CB}\n")
            guard_close(f, b.guard, b.protect)
            fprint(f, "\n")
            header_lines |> push(build_flags_header(b))
        }
        // registration
        fprint(f, "void das_vulkan_init_flags(Module & mod, ModuleLibrary & lib) {OB}\n")
        for (b in em.bitfields) {
            guard_open(f, b.guard, b.protect)
            fprint(f, "    mod.addAlias(makeVkFlags_{b.flags_name}());\n")
            for (al in b.aliases) {
                fprint(f, "    {OB} auto td = makeVkFlags_{b.flags_name}(); td->alias = \"{al}\"; mod.addAlias(td); {CB}\n")
            }
            let cbf = b.is64 ? "Bitfield64" : "Bitfield"
            let cuint = b.is64 ? "uint64_t" : "uint32_t"
            for (mb in b.multibit) {
                fprint(f, "    addConstant<{cbf}>(mod, \"{mb}\", {cbf}({cuint}({mb})));\n")
            }
            guard_close(f, b.guard, b.protect)
        }
        fprint(f, "{CB}\n\n{CB}\n")
    }
}

def private build_flags_header(b : BitfieldSpec) : string {
    return build_string() $(var w) {
        let has_g = !empty(b.guard)
        if (has_g) {
            if (!empty(b.protect)) {
                w |> write("#if defined({b.guard}) && defined({b.protect})\n")
            } else {
                w |> write("#if defined({b.guard})\n")
            }
        }
        w |> write("namespace das {OB} TypeDeclPtr makeVkFlags_{b.flags_name}(); {CB}\n")
        if (!b.is64 && !empty(b.bits_enum)) {
            // 32-bit FlagBits is a real C enum: route its typeFactory at the named bitfield
            w |> write("namespace das {OB}\n")
            w |> write("    template <> struct typeFactory<{b.bits_enum}> {OB}\n")
            w |> write("        static TypeDeclPtr make(const ModuleLibrary &) {OB} return makeVkFlags_{b.flags_name}(); {CB}\n")
            w |> write("    {CB};\n")
            w |> write("    template <> struct cast<{b.bits_enum}> : cast_enum<{b.bits_enum}> {OB}{CB};\n")
            w |> write("{CB}\n")
        }
        if (has_g) {
            w |> write("#endif\n")
        }
    }
}

// ===== emission: handles =====

def public emit_handles(reg : VkRegistry; em : EmitModel; out_dir : string; var header_lines : array<string>) {
    fopen("{out_dir}/dasVULKAN.gen_handles.cpp", "wb") $(f) {
        panic("can't write gen_handles") if (f == null)
        fprint(f, GEN_HEADER)
        fprint(f, "#include \"dasVULKAN.h\"\n\nnamespace das {OB}\n\n")
        fprint(f, "void das_vulkan_init_handles(Module & mod, ModuleLibrary & lib) {OB}\n")
        for (h in reg.handles) {
            continue if (!empty(h.alias) || !key_exists(em.handle_names, h.name))
            guard_open(f, h.guard, h.protect)
            fprint(f, "    mod.addAnnotation(new DummyTypeAnnotation(\"{h.name}_T\", \"{h.name}_T\", 1, 1));\n")
            fprint(f, "    {OB} auto td = makeType<{h.name}_T *>(lib); td->alias = \"{h.name}\"; mod.addAlias(td); {CB}\n")
            guard_close(f, h.guard, h.protect)
            header_lines |> push(build_handle_header(h))
        }
        // handle aliases
        for (h in reg.handles) {
            continue if (empty(h.alias) || !key_exists(reg.enabled_types, h.name) || !key_exists(em.handle_names, h.alias))
            guard_open(f, h.guard, h.protect)
            fprint(f, "    {OB} auto td = makeType<{h.alias}_T *>(lib); td->alias = \"{h.name}\"; mod.addAlias(td); {CB}\n")
            guard_close(f, h.guard, h.protect)
        }
        fprint(f, "{CB}\n\n{CB}\n")
    }
}

def private build_handle_header(h : VkHandleDef) : string {
    return build_string() $(var w) {
        let has_g = !empty(h.guard)
        if (has_g) {
            if (!empty(h.protect)) {
                w |> write("#if defined({h.guard}) && defined({h.protect})\n")
            } else {
                w |> write("#if defined({h.guard})\n")
            }
        }
        w |> write("MAKE_TYPE_FACTORY({h.name}_T, {h.name}_T)\n")
        if (has_g) {
            w |> write("#endif\n")
        }
    }
}

// ===== emission: structs =====

def private elem_typedecl_text(reg : VkRegistry; em : EmitModel; tn : string) : string {
    if (tn == "char") {
        return "makeType<int8_t>(*mlib)"
    }
    let sc = SCALAR_MAP?[tn] ?? ""
    if (!empty(sc)) {
        return "makeType<{sc}>(*mlib)"
    }
    let fi = em.flags_lookup?[tn] ?? FlagsInfo()
    if (fi.kind != FlagsKind.not_flags) {
        return "makeVkFlags_{fi.canonical}()"
    }
    let bt = reg.base_types?[tn] ?? ""
    if (!empty(bt)) {
        let bsc = SCALAR_MAP?[bt] ?? ""
        if (!empty(bsc)) {
            return "makeType<{bsc}>(*mlib)"
        }
    }
    return "makeType<{tn}>(*mlib)"
}

//! "" when the plain DAS_BIND_MANAGED_FIELD path applies; otherwise the explicit TypeDecl text.
//! All pointer fields are bound const-stripped (writable) so CreateInfo structs are fillable das-side.
[unused_argument(s)]
def private field_override_text(reg : VkRegistry; em : EmitModel; s : VkStructDef; m : VkMember) : string {
    let tn = m.type_name
    let np = m.num_ptrs
    // function-pointer fields (PFN_* typedef IS the pointer, so num_ptrs==0) -> void*
    if (key_exists(reg.func_pointers, tn)) {
        return "makeType<void *>(*mlib)"
    }
    // fixed arrays: nested makeFixedArrayTypeDecl, outermost first
    if (!empty(m.arr_dims)) {
        return build_string() $(var w) {
            for (d in m.arr_dims) {
                w |> write("makeFixedArrayTypeDecl(int32_t({d}), ")
            }
            w |> write(elem_typedecl_text(reg, em, tn))
            for (_d in m.arr_dims) {
                w |> write(")")
            }
        }
    }
    // pointer fields -- strip const (the C decl is usually `const X*`, which decltype binds
    // as a const, non-assignable field). Bind as a writable typed pointer / string / void*.
    if (np >= 1) {
        // foreign / void / ptr-to-ptr (string arrays, out-arrays): raw void*; boost types it
        if (!empty(FOREIGN_MAP?[tn] ?? "") || tn == "void" || np >= 2) {
            return "makeType<void *>(*mlib)"
        }
        if (tn == "char") {
            return "makeType<char *>(*mlib)"        // const char* -> writable string
        }
        // single pointer to a concrete C type (struct / enum / scalar / base typedef / flags)
        return "makeType<{tn} *>(*mlib)"
    }
    // non-pointer overrides
    let fm = FOREIGN_MAP?[tn] ?? ""
    if (!empty(fm) && fm != "void") {
        return "makeType<{fm}>(*mlib)"
    }
    if (tn == "size_t") {
        return "makeType<uint64_t>(*mlib)"
    }
    let fi = em.flags_lookup?[tn] ?? FlagsInfo()
    if (fi.kind == FlagsKind.flags32 || fi.kind == FlagsKind.flags64 || fi.kind == FlagsKind.flag_bits64) {
        return "makeVkFlags_{fi.canonical}()"
    }
    return ""
}

def public emit_structs(reg : VkRegistry; em : EmitModel; out_dir : string; var add_fns : array<string>; var fill_fns : array<string>; var header_lines : array<string>) {
    let per_chunk = 50
    var emitted : array<int>
    for (s, idx in reg.structs, range(length(reg.structs))) {
        continue if (!empty(s.alias) || !key_exists(em.struct_emit, s.name))
        emitted |> push(idx)
    }
    var chunk = 0
    var i = 0
    while (i < length(emitted)) {
        let hi = min(i + per_chunk, length(emitted))
        fopen("{out_dir}/dasVULKAN.gen_structs_{chunk}.cpp", "wb") $(f) {
            panic("can't write gen_structs_{chunk}") if (f == null)
            fprint(f, GEN_HEADER)
            fprint(f, "#include \"dasVULKAN.h\"\n\nnamespace das {OB}\n\n")
            for (j in range(i, hi)) {
                let s & = unsafe(reg.structs[emitted[j]])
                guard_open(f, s.guard, s.protect)
                fprint(f, "struct {s.name}_Ann : ManagedStructureAnnotation<{s.name}> {OB}\n")
                fprint(f, "    {s.name}_Ann(ModuleLibrary & ml) : ManagedStructureAnnotation(\"{s.name}\", ml, \"{s.name}\") {OB}{CB}\n")
                fprint(f, "    virtual bool isLocal() const override {OB} return true; {CB}\n")
                fprint(f, "    virtual bool canCopy() const override {OB} return true; {CB}\n")
                fprint(f, "    virtual bool canMove() const override {OB} return true; {CB}\n")
                fprint(f, "    void init();\n")
                fprint(f, "{CB};\n")
                fprint(f, "static {s.name}_Ann * ann_{s.name} = nullptr;\n")
                fprint(f, "void {s.name}_Ann::init() {OB}\n")
                for (m in s.members) {
                    let das_name = das_safe_name(m.name)
                    let ov = field_override_text(reg, em, s, m)
                    if (empty(ov)) {
                        fprint(f, "    addField<DAS_BIND_MANAGED_FIELD({m.name})>(\"{das_name}\", \"{m.name}\");\n")
                    } else {
                        fprint(f, "    addFieldEx(\"{das_name}\", \"{m.name}\", offsetof({s.name}, {m.name}), {ov});\n")
                    }
                }
                fprint(f, "{CB}\n")
                guard_close(f, s.guard, s.protect)
                fprint(f, "\n")
                header_lines |> push(build_struct_header(s))
            }
            // add + fill functions for this chunk
            fprint(f, "void das_vulkan_add_structs_{chunk}(Module & mod, ModuleLibrary & lib) {OB}\n")
            for (j in range(i, hi)) {
                let s & = unsafe(reg.structs[emitted[j]])
                guard_open(f, s.guard, s.protect)
                fprint(f, "    ann_{s.name} = new {s.name}_Ann(lib); mod.addAnnotation(ann_{s.name});\n")
                guard_close(f, s.guard, s.protect)
            }
            fprint(f, "{CB}\n\n")
            fprint(f, "void das_vulkan_fill_structs_{chunk}(Module & mod, ModuleLibrary & lib) {OB}\n")
            for (j in range(i, hi)) {
                let s & = unsafe(reg.structs[emitted[j]])
                guard_open(f, s.guard, s.protect)
                fprint(f, "    ann_{s.name}->mlib = &lib; ann_{s.name}->init(); ann_{s.name}->mlib = nullptr;\n")
                guard_close(f, s.guard, s.protect)
            }
            fprint(f, "{CB}\n\n{CB}\n")
        }
        add_fns |> push("das_vulkan_add_structs_{chunk}")
        fill_fns |> push("das_vulkan_fill_structs_{chunk}")
        chunk++
        i = hi
    }
    emit_struct_aliases(reg, em, out_dir)
}

def private build_struct_header(s : VkStructDef) : string {
    return build_string() $(var w) {
        let has_g = !empty(s.guard)
        if (has_g) {
            if (!empty(s.protect)) {
                w |> write("#if defined({s.guard}) && defined({s.protect})\n")
            } else {
                w |> write("#if defined({s.guard})\n")
            }
        }
        w |> write("MAKE_TYPE_FACTORY({s.name}, {s.name})\n")
        if (has_g) {
            w |> write("#endif\n")
        }
    }
}

def private emit_struct_aliases(reg : VkRegistry; em : EmitModel; out_dir : string) {
    fopen("{out_dir}/dasVULKAN.gen_struct_aliases.cpp", "wb") $(f) {
        panic("can't write gen_struct_aliases") if (f == null)
        fprint(f, GEN_HEADER)
        fprint(f, "#include \"dasVULKAN.h\"\n\nnamespace das {OB}\n\n")
        fprint(f, "void das_vulkan_init_struct_aliases(Module & mod, ModuleLibrary & lib) {OB}\n")
        for (s in reg.structs) {
            continue if (empty(s.alias) || !key_exists(reg.enabled_types, s.name))
            let target = resolve_struct_alias(reg, s.alias)
            continue if (empty(target) || !key_exists(em.struct_emit, target))
            guard_open(f, s.guard, s.protect)
            fprint(f, "    {OB} auto td = makeType<{target}>(lib); td->alias = \"{s.name}\"; mod.addAlias(td); {CB}\n")
            guard_close(f, s.guard, s.protect)
        }
        fprint(f, "{CB}\n\n{CB}\n")
    }
}

// ===== emission: commands =====

struct MappedParam {
    ok : bool
    reason : string
    cpp_param : string      //! "const VkInstanceCreateInfo & pCreateInfo"
    call_arg : string       //! "&pCreateInfo"
    das_arg : string        //! arg name for ->args
}

def private map_param(reg : VkRegistry; em : EmitModel; p : VkMember) : MappedParam {
    var r = MappedParam(ok = true, das_arg = das_safe_name(p.name))
    let tn = p.type_name
    let n = p.name
    let np = p.num_ptrs
    let cst = p.is_const
    let has_len = !empty(p.len)
    let optional_true = p.optional_attr == "true"
    // C-array parameter (const Elem name[N]): pass a pointer to the element; it decays
    // to the C array param. tn is the real C type name from the header (float, an enum, ...).
    if (!empty(p.arr_dims)) {
        r.cpp_param = cst ? "const {tn} * {n}" : "{tn} * {n}"
        r.call_arg = n
        return <- r
    }
    // funcpointer
    if (key_exists(reg.func_pointers, tn)) {
        return MappedParam(ok = false, reason = "funcpointer param {tn}")
    }
    // foreign
    let fm = FOREIGN_MAP?[tn] ?? ""
    if (!empty(fm)) {
        if (np > 0 || fm == "void" || (fm |> ends_with("*"))) {
            r.cpp_param = "void * {n}"
            r.call_arg = np > 0 ? "({tn} *){n}" : "({tn}){n}"
        } else {
            r.cpp_param = "{fm} {n}"
            r.call_arg = "({tn}){n}"
        }
        return <- r
    }
    // flags
    let fi = em.flags_lookup?[tn] ?? FlagsInfo()
    if (fi.kind != FlagsKind.not_flags) {
        if (np == 0) {
            if (fi.kind == FlagsKind.flag_bits32) {
                r.cpp_param = "{tn} {n}"
                r.call_arg = n
            } elif (fi.kind == FlagsKind.flags32) {
                r.cpp_param = "Bitfield {n}"
                r.call_arg = "({tn})({n}.value)"
            } else {
                r.cpp_param = "Bitfield64 {n}"
                r.call_arg = "({tn})({n}.value)"
            }
        } else {
            // pointer-to-flags (query out-params) -- raw uint pointer
            let cu = (fi.kind == FlagsKind.flags32 || fi.kind == FlagsKind.flag_bits32) ? "uint32_t" : "uint64_t"
            r.cpp_param = "{cu} * {n}"
            r.call_arg = "({tn} *){n}"
        }
        return <- r
    }
    // void pointers
    if (tn == "void") {
        if (np == 1) {
            r.cpp_param = cst ? "const void * {n}" : "void * {n}"
        } elif (np == 2) {
            r.cpp_param = "void ** {n}"
        } else {
            return MappedParam(ok = false, reason = "void param shape")
        }
        r.call_arg = n
        return <- r
    }
    // strings
    if (tn == "char") {
        if (np == 1 && cst) {
            r.cpp_param = "const char * {n}"
            r.call_arg = n
            return <- r
        }
        return MappedParam(ok = false, reason = "char pointer shape {np}")
    }
    // scalars and base types
    var sc = SCALAR_MAP?[tn] ?? ""
    if (empty(sc)) {
        let bt = reg.base_types?[tn] ?? ""
        if (!empty(bt)) {
            sc = SCALAR_MAP?[bt] ?? ""
        }
    }
    if (!empty(sc)) {
        if (np == 0) {
            r.cpp_param = "{sc} {n}"
            r.call_arg = (tn == "size_t") ? "(size_t){n}" : n
        } elif (np == 1) {
            if (!has_len && !optional_true && !cst) {
                r.cpp_param = "{sc} & {n}"
                r.call_arg = "({tn} *)&{n}"
            } else {
                r.cpp_param = cst ? "const {sc} * {n}" : "{sc} * {n}"
                r.call_arg = "({tn} *){n}"
            }
        } else {
            return MappedParam(ok = false, reason = "scalar ptr depth {np}")
        }
        return <- r
    }
    // handles
    if (key_exists(em.handle_names, tn)) {
        if (np == 0) {
            r.cpp_param = "{tn} {n}"
            r.call_arg = n
        } elif (np == 1) {
            if (!has_len && !optional_true && !cst) {
                r.cpp_param = "{tn} & {n}"
                r.call_arg = "&{n}"
            } else {
                r.cpp_param = cst ? "const {tn} * {n}" : "{tn} * {n}"
                r.call_arg = n
            }
        } else {
            return MappedParam(ok = false, reason = "handle ptr depth {np}")
        }
        return <- r
    }
    // plain enums
    if (key_exists(em.plain_enums, tn)) {
        if (np == 0) {
            r.cpp_param = "{tn} {n}"
            r.call_arg = n
        } elif (np == 1 && !cst && !has_len && !optional_true) {
            r.cpp_param = "{tn} & {n}"
            r.call_arg = "&{n}"
        } elif (np == 1) {
            r.cpp_param = cst ? "const {tn} * {n}" : "{tn} * {n}"
            r.call_arg = n
        } else {
            return MappedParam(ok = false, reason = "enum ptr depth {np}")
        }
        return <- r
    }
    // structs / unions
    if (key_exists(reg.struct_index, tn)) {
        if (!key_exists(em.struct_emit, tn)) {
            return MappedParam(ok = false, reason = "param type {tn} not emitted")
        }
        if (np == 1) {
            if (!has_len && !optional_true) {
                r.cpp_param = cst ? "const {tn} & {n}" : "{tn} & {n}"
                r.call_arg = "&{n}"
            } else {
                r.cpp_param = cst ? "const {tn} * {n}" : "{tn} * {n}"
                r.call_arg = n
            }
            return <- r
        }
        if (np == 2 && cst) {
            // const T* const* (jagged array of T): bind the double pointer NON-const so
            // das sees a plain T?? matching array_addr of an array<T?>; the boost wrapper
            // builds the pointer-of-pointers, the C call casts the const back on.
            r.cpp_param = "{tn} ** {n}"
            r.call_arg = "(const {tn} * const *){n}"
            return <- r
        }
        return MappedParam(ok = false, reason = "struct ptr depth {np}")
    }
    return MappedParam(ok = false, reason = "unknown param type {tn}")
}

struct MappedRet {
    ok : bool
    reason : string
    cpp_ret : string
    wrap_open : string      //! e.g. "return Bitfield(uint32_t("
    wrap_close : string     //! e.g. "))"
}

def private map_ret(reg : VkRegistry; em : EmitModel; tn : string) : MappedRet {
    if (tn == "void") {
        return MappedRet(ok = true, cpp_ret = "void", wrap_open = "", wrap_close = "")
    }
    if (key_exists(reg.func_pointers, tn)) {
        return MappedRet(ok = false, reason = "funcpointer return")
    }
    let fi = em.flags_lookup?[tn] ?? FlagsInfo()
    if (fi.kind != FlagsKind.not_flags) {
        if (fi.kind == FlagsKind.flags32 || fi.kind == FlagsKind.flag_bits32) {
            return MappedRet(ok = true, cpp_ret = "Bitfield", wrap_open = "return Bitfield(uint32_t(", wrap_close = "))")
        }
        return MappedRet(ok = true, cpp_ret = "Bitfield64", wrap_open = "return Bitfield64(uint64_t(", wrap_close = "))")
    }
    if (key_exists(em.plain_enums, tn) || key_exists(em.handle_names, tn)) {
        return MappedRet(ok = true, cpp_ret = tn, wrap_open = "return ", wrap_close = "")
    }
    var sc = SCALAR_MAP?[tn] ?? ""
    if (empty(sc)) {
        let bt = reg.base_types?[tn] ?? ""
        if (!empty(bt)) {
            sc = SCALAR_MAP?[bt] ?? ""
        }
    }
    if (!empty(sc)) {
        return MappedRet(ok = true, cpp_ret = sc, wrap_open = "return ({sc})", wrap_close = "")
    }
    return MappedRet(ok = false, reason = "unsupported return {tn}")
}

def public emit_funcs(reg : VkRegistry; em : EmitModel; out_dir : string; var init_fns : array<string>; var skip_log : array<string>) {
    let per_chunk = 40
    // resolve commands: aliases borrow the canonical signature, call their own name
    var work : array<tuple<cmd_idx : int; sig_idx : int>>
    for (c, idx in reg.commands, range(length(reg.commands))) {
        continue if (!key_exists(reg.enabled_commands, c.name))
        let guard = reg.enabled_commands?[c.name] ?? ""
        let protect = reg.ext_protect?[guard] ?? ""
        continue if (!supported(protect))
        var sig = idx
        if (!empty(c.alias)) {
            sig = reg.command_index?[c.alias] ?? -1
            if (sig < 0) {
                skip_log |> push("{c.name}: alias target {c.alias} not found")
                continue
            }
        }
        work |> push((cmd_idx = idx, sig_idx = sig))
    }
    var chunk = 0
    var i = 0
    while (i < length(work)) {
        let hi = min(i + per_chunk, length(work))
        fopen("{out_dir}/dasVULKAN.gen_funcs_{chunk}.cpp", "wb") $(f) {
            panic("can't write gen_funcs_{chunk}") if (f == null)
            fprint(f, GEN_HEADER)
            fprint(f, "#include \"dasVULKAN.h\"\n\nnamespace das {OB}\n\n")
            var reg_lines : array<string>
            for (j in range(i, hi)) {
                let c & = unsafe(reg.commands[work[j].cmd_idx])
                let sig & = unsafe(reg.commands[work[j].sig_idx])
                let guard = reg.enabled_commands?[c.name] ?? ""
                let protect = reg.ext_protect?[guard] ?? ""
                let mr = map_ret(reg, em, sig.ret_type)
                if (!mr.ok) {
                    skip_log |> push("{c.name}: {mr.reason}")
                    continue
                }
                var params : array<MappedParam>
                var all_ok = true
                for (p in sig.params) {
                    var mp <- map_param(reg, em, p)
                    if (!mp.ok) {
                        skip_log |> push("{c.name}: param {p.name}: {mp.reason}")
                        all_ok = false
                    }
                    params |> emplace(mp)
                    break if (!all_ok)
                }
                continue if (!all_ok)
                guard_open(f, guard, protect)
                fprint(f, "static {mr.cpp_ret} WRAP_{c.name} ( ")
                for (mp, pi in params, range(length(params))) {
                    if (pi != 0) {
                        fprint(f, ", ")
                    }
                    fprint(f, "{mp.cpp_param}")
                }
                fprint(f, " ) {OB}\n    ")
                if (sig.ret_type == "void") {
                    fprint(f, "::{c.name}(")
                } else {
                    fprint(f, "{mr.wrap_open}::{c.name}(")
                }
                for (mp, pi in params, range(length(params))) {
                    if (pi != 0) {
                        fprint(f, ", ")
                    }
                    fprint(f, "{mp.call_arg}")
                }
                if (sig.ret_type == "void") {
                    fprint(f, ");\n{CB}\n")
                } else {
                    fprint(f, "){mr.wrap_close};\n{CB}\n")
                }
                guard_close(f, guard, protect)
                fprint(f, "\n")
                // registration line
                let rl = build_string() $(var w) {
                    if (!empty(guard)) {
                        if (!empty(protect)) {
                            w |> write("#if defined({guard}) && defined({protect})\n")
                        } else {
                            w |> write("#if defined({guard})\n")
                        }
                    }
                    w |> write("    addExtern<DAS_BIND_FUN(WRAP_{c.name})>(mod, lib, \"{c.name}\", SideEffects::modifyArgumentAndExternal, \"WRAP_{c.name}\")")
                    if (!empty(params)) {
                        w |> write("\n        ->args({OB}")
                        for (mp, pi in params, range(length(params))) {
                            if (pi != 0) {
                                w |> write(",")
                            }
                            w |> write("\"{mp.das_arg}\"")
                        }
                        w |> write("{CB})")
                    }
                    w |> write(";\n")
                    if (!empty(guard)) {
                        w |> write("#endif\n")
                    }
                }
                reg_lines |> push(rl)
            }
            fprint(f, "void das_vulkan_init_funcs_{chunk}(Module & mod, ModuleLibrary & lib) {OB}\n")
            for (rl in reg_lines) {
                fprint(f, rl)
            }
            fprint(f, "{CB}\n\n{CB}\n")
        }
        init_fns |> push("das_vulkan_init_funcs_{chunk}")
        chunk++
        i = hi
    }
}

// ===== gen.h + init registry =====

def public emit_gen_header(out_dir : string; header_lines : array<string>; all_init_decls : array<string>) {
    fopen("{out_dir}/dasVULKAN.gen.h", "wb") $(f) {
        panic("can't write gen.h") if (f == null)
        fprint(f, GEN_HEADER)
        fprint(f, "#pragma once\n\n")
        for (hl in header_lines) {
            fprint(f, hl)
        }
        fprint(f, "\nnamespace das {OB}\n")
        for (d in all_init_decls) {
            fprint(f, "void {d}(Module & mod, ModuleLibrary & lib);\n")
        }
        fprint(f, "{CB}\n")
    }
}

def public emit_init(out_dir : string; ordered_calls : array<string>) {
    fopen("{out_dir}/dasVULKAN.gen_init.cpp", "wb") $(f) {
        panic("can't write gen_init") if (f == null)
        fprint(f, GEN_HEADER)
        fprint(f, "#include \"dasVULKAN.h\"\n\nnamespace das {OB}\n\n")
        fprint(f, "void das_vulkan_init_generated(Module & mod, ModuleLibrary & lib) {OB}\n")
        for (cname in ordered_calls) {
            fprint(f, "    {cname}(mod, lib);\n")
        }
        fprint(f, "{CB}\n\n{CB}\n")
    }
}

// ===== orchestrator =====

def public emit_all(reg : VkRegistry; em : EmitModel; out_dir : string) {
    var header_lines : array<string>
    var enum_init_fns : array<string>
    var struct_add_fns : array<string>
    var struct_fill_fns : array<string>
    var func_init_fns : array<string>
    var skip_log : array<string>
    emit_consts(reg, out_dir)
    emit_enums(reg, em, out_dir, enum_init_fns, header_lines)
    emit_flags(reg, em, out_dir, header_lines)
    emit_handles(reg, em, out_dir, header_lines)
    emit_structs(reg, em, out_dir, struct_add_fns, struct_fill_fns, header_lines)
    emit_funcs(reg, em, out_dir, func_init_fns, skip_log)
    var ordered : array<string>
    ordered |> push("das_vulkan_init_consts")
    ordered |> push_from(enum_init_fns)
    ordered |> push("das_vulkan_init_flags")
    ordered |> push("das_vulkan_init_handles")
    ordered |> push_from(struct_add_fns)
    ordered |> push("das_vulkan_init_struct_aliases")
    ordered |> push_from(struct_fill_fns, func_init_fns)
    emit_gen_header(out_dir, header_lines, ordered)
    emit_init(out_dir, ordered)
    // report
    to_log(LOG_INFO, "emitted: {length(em.struct_emit)} structs, {length(em.bitfields)} bitfields, {length(em.plain_enums)} enums\n")
    to_log(LOG_INFO, "skipped structs: {length(em.skipped)}\n")
    to_log(LOG_INFO, "skipped commands/params: {length(skip_log)}\n")
    for (sl in skip_log) {
        to_log(LOG_INFO, "  skip: {sl}\n")
    }
}