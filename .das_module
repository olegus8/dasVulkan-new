options gen2
require daslib/fio

[export]
def initialize(project_path : string) {
    if (das_is_dll_build()) {
        register_dynamic_module("{project_path}/dasModuleVulkan.shared_module", "Module_dasVULKAN")
    }
    register_native_path("vulkan", "vulkan_boost", "{project_path}/daslib/vulkan_boost.das")
}
