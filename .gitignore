# build dirs
_build/
build/
out/

# native module artifacts
*.shared_module
*.lib
*.exp
*.pdb
*.ilk
*.obj
# mesh assets (Wavefront OBJ) are NOT C++ object files -- keep them tracked
!tutorials/_assets/**/*.obj

# runtime / scratch
*.log
*.ppm
_smoke_*.das
imgui.ini

# docs build artifacts (Sphinx domain bytecode + generated site)
__pycache__/
*.pyc
_site/

# Sphinx reference content emitted by utils/vulkan2rst.das — regenerated in the
# docs CI job before every build, never tracked. The hand-filled module intros
# under stdlib/handmade/ ARE tracked (vulkan2rst only stubs them if absent).
doc/source/stdlib/generated/

# daspkg install dir + index cache (created by `daspkg install` / `daspkg introduce`)
modules/

# tutorial recording intermediates -- only the .mp4 doc figure is tracked; the
# APNG, the strudel music-bed wav, and any scratch frames are regenerated locally
# by tutorials/*/recording/record_*.das (which need stbimage + audio, absent in CI).
tutorials/**/recording/*.apng
tutorials/**/recording/*.wav
tutorials/**/recording/*.png
tutorials/**/recording/voiceover/
tutorials/**/*.mp4.ffmpeg.txt

# Sphinx build-time copies of tutorial recordings (the tracked source is
# tutorials/<name>/*.mp4; conf.py copies them here at build).
doc/source/_static/tutorials/
